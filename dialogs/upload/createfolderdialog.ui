QComboBox QAbstractItemView { outline: 0px;}
QLineEdit,
QComboBox{
  subcontrol-origin: padding;
  subcontrol-position: top right;
  selection-background-color: #40404A;
  selection-color: #3B3B41;
  color: #99A1B0;
  height:24px;
  background-color: #212126;
  border-style: solid;
  border: 1px solid #0F0F0F;
  border-radius: 4;
  padding: 1px 0px 1px 2px;
  font-size: 12px;
  font-family:Microsoft YaHei UI;
  padding-left:8px;
  }


  QComboBOx:hover
  {
  border: 1px #40404A;
  background-color:#40404A;
  color: white;
  }


  QComboBox:on
  {
  padding-top: 0px;
  padding-left: 0px;
  color: #99A1B0;
  background-color: #40404A;
  selection-background-color: #3B3B41;
  }

  QComboBox:!on
  {
  color: #99A1B0;
  }


  QComboBox QAbstractItemView
  {
  border: 0px solid darkgray;
  color: white;
  background-color:#212126;
  selection-background-color: #454549;
height:24px;
  }


  QComboBox QAbstractItemView::item
  {
  qproperty-elide-mode: '...';
  height:24px;
outline: 0px;
  }


  QComboBox::drop-down
  {
  subcontrol-origin: padding;
  subcontrol-position: top right;
  width: 15px;
  color: white;
  border-left-width: 0px;
  border-left-color: darkgray;
  border-left-style: solid;
  border-top-right-radius: 2px;
  border-bottom-right-radius: 2px;
  padding-right: 0px;
  }

  QComboBox::down-arrow
  {
  image: url(:/icons/images/comboBoxExpander.svg);
  width: 8px;
  height: 4px;
  }

QListWidget{outline:0px;}
QListView {
  border-radius: 4px;
  padding: 5px;
  margin: 0px;
}

QTableView::item,
QTreeView::item,
QListView::item {
  padding: 5px;
  height: 22px;
  color: #99A1B0;
  selection-color: white;
  border-color: transparent; 
  border-radius: 4px;
outline: 0px;
}



QTableView:item:selected,
QTreeView::item:selected,
QListView::item:selected {
  background-color: #40404A;
  selection-background-color:  #3B3B41;
  color: #99A1B0;
  selection-color:  white;
  border-radius: 4px;
}

QTableView:item:selected:focus,
QTreeView::item:selected:focus,
QListView::item:selected:focus {
  background-color: #40404A;
  selection-background-color:#3B3B41;
  color:  #99A1B0;
  selection-color: white; 
}
