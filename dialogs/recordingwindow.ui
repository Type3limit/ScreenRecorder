}


QFrame#countDownFrame
{
background-color:#212126;
border-radius:4px;
  border: 0px solid #0F0F0F;
}

QCheckBox,
QLabel
{
color:#ffffff;
font-size:12px;
font-family:Microsoft YaHei UI;
}
QFrame#line,
#line_1,
#line_2,
#line_3,
#line_4
{
background-color:#353539;
}

QLineEdit {
    color: #ffffff;
    background-color: #212126;
    border: 1px solid #0f0f0f;
    border-radius: 4px;
    font-size: 12px;
    font-family: Microsoft YaHei UI, Microsoft YaHei UI-400;
    font-weight: 400;
    text-align: JUSTIFIED;
    line-height: 18px;
    padding-left:8px;
}

QLineEdit:hover {
    border-radius: 4px;
    border: 1px solid #5967f2;
}


QLineEdit:hover[state = 'danger'] {
    border-radius: 4px;
    border: 1px solid #e64b3d;
}

QLineEdit:disabled {
    color: #a0a0a4;
}


QComboBox {
    background-color: #212126;
    border: 1px solid #0f0f0f;
    border-radius: 4px;
    font-family: Microsoft YaHei UI, Microsoft YaHei UI-400;
    font-weight: 400;
    text-align: LEFT;
    color: #ffffff;
    line-height: 15px;
    padding-left:8px;
    padding-right:10px;
}


QComboBox:hover {
    border: 1px solid #5967f2;
}

QComboBox:disabled {
    color: #545353;
}


QComboBox::drop-down {
    right:5px;
    border: none;
}

QComboBox::down-arrow:on {
    width: 12px;
    height: 6px;
    image: url(:/icons/images/ic_combobox_up_light.svg);
}

QComboBox::down-arrow {
    width: 12px;
    height: 6px;
    image: url(:/icons/images/ic_combobox_down_dark.svg);
}


QComboBox::down-arrow:disabled {
    width: 12px;
    height: 6px;
    image: url(:/icons/images/ic_combobox_down_disable.svg);
}

QComboBox QAbstractItemView {
    outline: 0px; /*È¥³ýitemÐéÏß¿ò*/
    border: none;
    border-radius: 4px;
    background: #34343d;
    padding-top: 8px;
    padding-bottom: 8px;
    padding-left:8px;
    padding-right:8px;
}


QComboBox QAbstractItemView::item {
    font-size: 12px;
    font-family: Microsoft YaHei UI, Microsoft YaHei UI-400;
    font-weight: 400;
    text-align: LEFT;
    color: #ffffff;
    line-height: 15px;
    height: 24px;
}



QComboBox QAbstractItemView::item:hover {
    border-radius: 4px;

    background-color: #40404a;
}

QComboBox QAbstractItemView::item:selected {
    border-radius: 4px;
    background-color: #40404a;
}

QScrollBar:vertical {
    width: 4px;
    background: #34343d;
    margin: 0px,0px,0px,0px;
    padding-top: 0px;
    padding-bottom: 0px;
}

QScrollBar::handle:vertical {
    width: 4px;
    background:  #424954;
    border-radius: 2px;
    min-height: 40;
}

QScrollBar::handle:vertical:hover {
    width: 4px;
    background:  #99a1b0;
    border-radius: 2px;
    min-height: 40;
}

QScrollBar::add-page:vertical {
    background:  #34343d;
    border-bottom-left-radius: 2px;
    border-bottom-right-radius: 2px;
}

QScrollBar::sub-page:vertical {
    background:  #34343d;
    border-top-left-radius: 2px;
    border-top-right-radius: 2px;
}

QAbstractSpinBox {
    color: #ffffff;
    border: none;
    padding-right: 20px;
    background-color: #212126;
    background-clip: content;
    border-radius: 4px;
    font-size: 12px;
    font-family: Microsoft YaHei UI, Microsoft YaHei UI-400;
    font-weight: 400;
    text-align: left;
    line-height: 15px;
}


QAbstractSpinBox::up-button {
    subcontrol-origin: padding;
    subcontrol-position: top right;
    width: 15px;
    background-color: #212126;
    border-top-left-radius: 4px;
    border-top-right-radius: 4px;
}


QAbstractSpinBox::up-arrow {
    image: url(:/icons/images/ic_up_arrow.svg);
    width: 10px;
    height: 4px;
}

QAbstractSpinBox::up-arrow:hover {
    image: url(:/icons/images/ic_up_arrow_hover.svg);
}

QAbstractSpinBox::up-arrow::pressed{
    image: url(:/icons/images/ic_up_arrow_hover.svg);
}

QAbstractSpinBox::down-button {
    subcontrol-origin: padding;
    subcontrol-position: bottom right;
    width: 15px;
    background-color: #212126;
    border-bottom-left-radius: 4px;
    border-bottom-right-radius: 4px;
}

QAbstractSpinBox::down-arrow {
    image: url(:/icons/images/ic_down_arrow.svg);
    width: 8px;
    height: 4px;
}

QAbstractSpinBox::down-arrow:hover {
    image: url(:/icons/images/ic_down_arrow_hover.svg);
}

QAbstractSpinBox::down-arrow::pressed {
    image: url(:/icons/images/ic_down_arrow_hover.svg);
}

QAbstractSpinBox:disabled,
QAbstractSpinBox::down-button:disabled,
QAbstractSpinBox::up-button:disabled {
    background-color: #2d2d35;
}


